  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Focus: Teaching the player how to use their hands.


    Interacting with
    the World:


    a. Grip Button (Side): Use this to Pick Up items like the First
    Aid items or traingles.


    b. Trigger Button (Front): To snap any grabbable
    object and place accordingly.


    c. Interaction Distance: Look for the White
    Ray coming from your hand. When it hits an object, the object will highlight.


    d.
    Dropping Items: Simply release the Grip button to drop an object.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
